{
  "name": "@mmm-studio/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "MMM Studio editor desktop app",
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron .",
    "bundle": "node scripts/bundle-editor.mjs",
    "build:mac": "npm run bundle && electron-builder --mac dmg zip --publish never",
    "build:windows": "npm run bundle && electron-builder --win nsis portable --x64 --publish never"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "studio.mmm.editor",
    "productName": "MMM Studio",
    "asar": true,
    "asarUnpack": [
      "bundle/**"
    ],
    "files": [
      "src/**/*",
      "bundle/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
